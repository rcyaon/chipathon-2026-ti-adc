VDXB7 net12 GND PWL(0.0000n 3.3 9600.0000n 3.3 9600.1000n 0 19200.0000n 0 19200.1000n 3.3 28800.0000n 3.3 28800.1000n 0 38400.0000n 0 
+ 38400.1000n 3.3 48000.0000n 3.3 48000.1000n 0 57600.0000n 0 57600.1000n 3.3 67200.0000n 3.3 67200.1000n 0 76800.0000n 0)

VDX8  net25 GND PWL(0.0000n 0 19200.0000n 0 19200.1000n 3.3 38400.0000n 3.3 38400.1000n 0 57600.0000n 0 57600.1000n 3.3 76800.0000n 3.3)

VDXB8 net13 GND PWL(0.0000n 3.3 19200.0000n 3.3 19200.1000n 0 38400.0000n 0 38400.1000n 3.3 57600.0000n 3.3 57600.1000n 0 76800.0000n 0)

VDX9  net26 GND PWL(0.0000n 0 38400.0000n 0 38400.1000n 3.3 76800.0000n 3.3)

VDXB9 net14 GND PWL(0.0000n 3.3 38400.0000n 3.3 38400.1000n 0 76800.0000n 0)

**** begin simulation control ****

.tran 2n 76.8u

.control
run
wrdata dac_transfer.txt net17
plot net17
.endc

* ---- Test 2: INL/DNL (now a REAL code-ordered sweep, k=0..255) ----
* Each code k held for 300ns starting at t=k*300ns. Sample near the end of
* each plateau (e.g. t=k*300n + 270n) to let switching settle before reading.
* LSB = VREF/256 (only Dx<1:4>=LSB nibble, Dx<6:9>=MSB nibble are real code
* bits; Dx<0>/Dx<5> are the fixed dummy caps Cg1/Cg2).
* Use compute_inl_dnl_full.py on dac_transfer.txt to get the full INL/DNL
* curve and max/min values -- not done inline here since 256 .meas
* statements would be unwieldy; the post-processing script is cleaner.

* ---- Test 3: worst-case major-carry transition (code 127 -> 128) ----
* This is the largest possible single-code step: MSB nibble goes 0111->1000
* while LSB nibble goes 1111->0000, so every real bit switches at once.
* Code 127 starts at t=127*300n=38100n, code 128 starts at t=38400n.
.meas tran vx_before_carry FIND V(net17) AT=38399n
.meas tran vx_after_carry  FIND V(net17) AT=38400.2n
.meas tran vx_settle_early FIND V(net17) AT=38410n
.meas tran vx_settle_late  FIND V(net17) AT=38699n
.meas tran carry_step_size    PARAM='vx_after_carry - vx_before_carry'
.meas tran carry_settle_delta PARAM='vx_settle_late - vx_settle_early'

**** end simulation control ****


* ============================================================
* CDAC cell: split MSB/LSB array with bridge cap, per-bit switches
* ============================================================
.subckt caps Dx_b<0> Dx_b<1> Dx_b<2> Dx_b<3> Vin Dx_b<4> GND Dx_b<5> Dx_b<6> Dx_b<7> VREF Dx_b<8> phi_s Dx_b<9> Dx<0> VDD Dx<1> Vx
+ Dx<2> Dx<3> Vx_lsb Dx<4> Dx<5> Dx<6> Dx<7> Dx<8> Dx<9>
XC1 net2 Vx_lsb cap_mim_2f0fF c_width=4e-6 c_length=4e-6 m=1
XC2 net1 Vx_lsb cap_mim_2f0fF c_width=4e-6 c_length=4e-6 m=1
XC3 net3 Vx_lsb cap_mim_2f0fF c_width=4e-6 c_length=4e-6 m=2
XC4 net4 Vx_lsb cap_mim_2f0fF c_width=4e-6 c_length=4e-6 m=4
XC5 net5 Vx_lsb cap_mim_2f0fF c_width=4e-6 c_length=4e-6 m=8
XC6 net6 Vx cap_mim_2f0fF c_width=4e-6 c_length=4e-6 m=1
XC7 net7 Vx cap_mim_2f0fF c_width=4e-6 c_length=4e-6 m=1
XC8 net8 Vx cap_mim_2f0fF c_width=4e-6 c_length=4e-6 m=2
XC9 net9 Vx cap_mim_2f0fF c_width=4e-6 c_length=4e-6 m=4
XC10 net10 Vx cap_mim_2f0fF c_width=4e-6 c_length=4e-6 m=8
XC11 Vx_lsb Vx cap_mim_2f0fF c_width=4.13e-6 c_length=4.13e-6 m=1
x1 VDD Dx<0> Dx_b<0> phi_s VREF Vin net2 GND transistors
x2 VDD Dx<1> Dx_b<1> phi_s VREF Vin net1 GND transistors
x3 VDD Dx<4> Dx_b<4> phi_s VREF Vin net5 GND transistors
x4 VDD Dx<2> Dx_b<2> phi_s VREF Vin net3 GND transistors
x5 VDD Dx<3> Dx_b<3> phi_s VREF Vin net4 GND transistors
x6 VDD Dx<5> Dx_b<5> phi_s VREF Vin net6 GND transistors
x8 VDD Dx<7> Dx_b<7> phi_s VREF Vin net8 GND transistors
x9 VDD Dx<6> Dx_b<6> phi_s VREF Vin net7 GND transistors
x10 VDD Dx<8> Dx_b<8> phi_s VREF Vin net9 GND transistors
x11 VDD Dx<9> Dx_b<9> phi_s VREF Vin net10 GND transistors
.ends

* ============================================================
* Per-bit switch cell: complementary VREF/GND transmission gates + sampling switch
* ============================================================
.subckt transistors VDD Dx Dx_b phi_s VREF Vin sw_node GND
XM3 sw_node Dx VREF GND nfet_03v3 L=0.28u W=0.22u nf=1 ad='int((nf+1)/2) * W/nf * 0.18u' as='int((nf+2)/2) * W/nf * 0.18u' pd='2*int((nf+1)/2) * (W/nf + 0.18u)'
+ ps='2*int((nf+2)/2) * (W/nf + 0.18u)' nrd='0.18u / W' nrs='0.18u / W' sa=0 sb=0 sd=0 m=1
XM4 sw_node Dx_b VREF VDD pfet_03v3 L=0.28u W=0.22u nf=1 ad='int((nf+1)/2) * W/nf * 0.18u' as='int((nf+2)/2) * W/nf * 0.18u' pd='2*int((nf+1)/2) * (W/nf + 0.18u)'
+ ps='2*int((nf+2)/2) * (W/nf + 0.18u)' nrd='0.18u / W' nrs='0.18u / W' sa=0 sb=0 sd=0 m=1
XM6 GND Dx_b sw_node GND nfet_03v3 L=0.28u W=0.22u nf=1 ad='int((nf+1)/2) * W/nf * 0.18u' as='int((nf+2)/2) * W/nf * 0.18u' pd='2*int((nf+1)/2) * (W/nf + 0.18u)'
+ ps='2*int((nf+2)/2) * (W/nf + 0.18u)' nrd='0.18u / W' nrs='0.18u / W' sa=0 sb=0 sd=0 m=1
XM7 GND Dx sw_node VDD pfet_03v3 L=0.28u W=0.22u nf=1 ad='int((nf+1)/2) * W/nf * 0.18u' as='int((nf+2)/2) * W/nf * 0.18u' pd='2*int((nf+1)/2) * (W/nf + 0.18u)'
+ ps='2*int((nf+2)/2) * (W/nf + 0.18u)' nrd='0.18u / W' nrs='0.18u / W' sa=0 sb=0 sd=0 m=1
XM1 Vin phi_s sw_node GND nfet_03v3 L=0.28u W=0.22u nf=1 ad='int((nf+1)/2) * W/nf * 0.18u' as='int((nf+2)/2) * W/nf * 0.18u' pd='2*int((nf+1)/2) * (W/nf + 0.18u)'
+ ps='2*int((nf+2)/2) * (W/nf + 0.18u)' nrd='0.18u / W' nrs='0.18u / W' sa=0 sb=0 sd=0 m=1
.ends

.end
