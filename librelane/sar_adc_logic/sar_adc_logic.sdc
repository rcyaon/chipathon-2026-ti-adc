# ==============================================================================
# 1. Primary External Clock (25 MHz)
# ==============================================================================
# This is the clock driven by your external digital logic
create_clock -name clk_i -period 40.0 [get_ports clk_i]

# ==============================================================================
# 2. Internal Self-Timed Clock (The Asynchronous Loop)
# ==============================================================================
# Because valid_clk is generated by the comparator (out_p ^ out_n) and has 
# NO phase relationship with clk_i, we define it as an independent clock.
# We set a tight 1.0 ns period (1 GHz) to force the synthesis tool to aggressively 
# optimize the critical path of the SAR sequence logic.
create_clock -name valid_clk -period 5 [get_ports {out_p out_n}]

# Tell the tool that these two clocks operate completely independently.
# This prevents Static Timing Analysis (STA) from trying to calculate setup/hold 
# times between the 25 MHz domain and the self-timed domain.
set_clock_groups -asynchronous -group {clk_i} -group {valid_clk}

# ==============================================================================
# 3. Macro I/O Boundary Constraints
# ==============================================================================
# Define how long it takes signals to arrive at your inputs.
# We give a generous 5ns delay estimate from the analog domain.
set_input_delay -clock clk_i 5.0 [get_ports {out_p out_n rst_n}]

# Define how much time the downstream logic needs.
set_output_delay -clock clk_i 5.0 [get_ports {dac_ctrl[*] dout[*] clk_o clk_o_n}]

# ==============================================================================
# 4. Analog Loading & Design Rules
# ==============================================================================
# Apply the 10 fF (0.01 pF) dummy capacitor load to all outputs so the digital 
# gates are sized correctly to drive your comparator and CDAC.
set_load 0.010 [all_outputs]

# Prevent the tool from using absurdly weak standard cells that cause slow rise times.
set_max_transition 1.0 [current_design]
set_max_fanout 16 [current_design]